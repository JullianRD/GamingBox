# --- Application ---
APP_FRONTEND_URL=http://localhost:3000
SESSION_SECRET=your_session_secret
CSRF_SECRET=your_csrf_secret

# --- Configuration Serveur ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Configuration Base de Données ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamingbox_db_dev
DB_USER=postgres
DB_PASSWORD=your_database_password

# --- Compte applicatif PostgreSQL ---
DB_APP_USER=app_gamingbox
DB_APP_PASSWORD=your_app_database_password

# --- Connection string utilisée par Node.js ---
DATABASE_URL=postgresql://postgres:your_database_password@localhost:5432/gamingbox_db_dev

# --- Configuration IGDB / Twitch ---
IGDB_CLIENT_ID=your_igdb_client_id
IGDB_CLIENT_SECRET=your_igdb_client_secret