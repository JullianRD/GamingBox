<!-- src/views/layouts/main.ejs -->
<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= typeof title !== 'undefined' ? title : 'GamingBox' %>
    </title>

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">

    <!-- Tailwind CSS v4 (CDN) -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <!-- CSS global (si nécessaire) -->
    <link rel="stylesheet" href="//public/css/main.css">

    <!-- Styles extraits des vues -->
    <%- typeof style !== "undefined" ? style : "" %>
</head>

<body class="min-h-screen flex flex-col bg-slate-950 text-slate-100">

    <!-- Navbar -->
    <header class="sticky top-0 z-50">
        <%- include('../partials/navbar') %>
    </header>

    <!-- Contenu principal -->
    <main class="
        flex-1
        w-full
        max-w-7xl
        mx-auto
        px-4
        sm:px-6
        lg:px-8
        py-6
    ">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-white/10">
        <%- include('../partials/footer') %>
    </footer>

    <!-- JS global -->
    <script src="/js/app.js"></script>

    <!-- Scripts extraits des vues -->
    <%- typeof script !== "undefined" ? script : "" %>
</body>

</html>