<div class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900 px-4 py-10">
  <div class="mx-auto max-w-6xl">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">🏷️ Tags</h1>
        <p class="mt-1 text-sm text-slate-400">Gestion globale des tags</p>
      </div>
      <a href="/admin" class="rounded-lg border border-slate-700 px-4 py-2 text-slate-200 hover:bg-slate-800">
        ← Retour admin
      </a>
    </div>

    <div class="grid gap-4">
      <% tags.forEach(item => { %>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <p class="text-lg font-semibold text-white"><%= item.tagName %></p>
            <p class="text-xs text-slate-500 mt-2">User ID : <%= item.userId %></p>
          </div>

          <form action="/admin/tags/<%= item.id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce tag ?');">
            <button class="rounded-lg border border-red-500/20 bg-red-500/10 px-4 py-2 text-red-300 hover:bg-red-500/20 transition">
              Supprimer
            </button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</div>