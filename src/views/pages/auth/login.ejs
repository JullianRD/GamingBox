<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900 px-4 py-10">
  <div class="w-full max-w-md rounded-2xl border border-purple-500/20 bg-white/5 backdrop-blur-xl shadow-2xl p-8">

    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Connexion</h1>
      <p class="text-slate-400 mt-2">
        Accède à ton espace GamingBox
      </p>
    </div>

    <!-- Message logout -->
    <% if (logoutSuccess) { %>
      <div class="mb-6 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-emerald-300">
        Déconnexion réussie ✅
      </div>
    <% } %>

    <!-- Flash success -->
    <% if (flash && flash.success) { %>
      <div class="mb-6 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-emerald-300">
        <%= flash.success %>
      </div>
    <% } %>

    <!-- Flash error -->
    <% if (flash && flash.error) { %>
      <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-300">
        <%= flash.error %>
      </div>
    <% } %>

    <!-- Form -->
    <form action="/login" method="POST" class="space-y-5">

      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm text-slate-300 mb-2">
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500 outline-none"
        >
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block text-sm text-slate-300 mb-2">
          Mot de passe
        </label>
        <input
          id="password"
          name="password"
          type="password"
          required
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500 outline-none"
        >
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full px-5 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-500 hover:to-indigo-500 transition shadow-lg shadow-purple-900/30"
      >
        Se connecter
      </button>

    </form>

    <!-- Register link -->
    <p class="text-sm text-slate-400 text-center mt-6">
      Pas encore de compte ?
      <a href="/register" class="text-purple-300 hover:text-purple-200 transition">
        Créer un compte
      </a>
    </p>

  </div>
</div>