<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900 px-4 py-10">
  <div class="w-full max-w-md rounded-2xl border border-purple-500/20 bg-white/5 p-8 shadow-2xl backdrop-blur-xl">

    <!-- Header -->
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-white">Connexion</h1>
      <p class="mt-2 text-sm text-slate-400">
        Connecte-toi à ton compte GamingBox
      </p>
    </div>

    <!-- Message logout -->
    <% if (typeof logoutSuccess !== "undefined" && logoutSuccess) { %>
      <div class="mb-6 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-emerald-300">
        Déconnexion réussie ✅
      </div>
    <% } %>

    <!-- Flash success -->
    <% if (flash && flash.success) { %>
      <div class="mb-6 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-emerald-300">
        <%= flash.success %>
      </div>
    <% } %>

    <!-- Flash error -->
    <% if (flash && flash.error) { %>
      <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-300">
        <%= flash.error %>
      </div>
    <% } %>

    <!-- Form -->
    <form action="/login" method="POST" class="space-y-5">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="email" class="mb-2 block text-sm text-slate-300">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-4 py-3 text-white focus:border-purple-500 outline-none"
          placeholder="ton@email.com"
        >
      </div>

      <div>
        <label for="password" class="mb-2 block text-sm text-slate-300">Mot de passe</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-4 py-3 text-white focus:border-purple-500 outline-none"
          placeholder="••••••••"
        >
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 px-5 py-3 font-medium text-white shadow-lg hover:from-purple-500 hover:to-indigo-500 transition"
      >
        Se connecter
      </button>
    </form>

    <!-- Bottom links -->
    <div class="mt-6 text-center text-sm text-slate-400">
      Pas encore de compte ?
      <a href="/register" class="text-purple-300 hover:text-purple-200 transition">
        Inscription
      </a>
    </div>
  </div>
</div>