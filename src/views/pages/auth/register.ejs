<div class="min-h-screen flex items-center justify-center px-4
            bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900">

    <div class="w-full max-w-md p-8 rounded-2xl 
                bg-white/5 backdrop-blur-xl 
                shadow-2xl border border-purple-500/20 
                relative overflow-hidden">

        <!-- Glow -->
        <div class="absolute -top-20 -left-20 w-40 h-40 bg-purple-600/30 blur-3xl rounded-full"></div>
        <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-indigo-600/20 blur-3xl rounded-full"></div>

        <!-- Header -->
        <div class="mb-6 text-center relative z-10">
            <h1 class="text-2xl font-bold text-white">
                🚀 Créer un compte
            </h1>
            <p class="text-sm text-slate-400 mt-2">
                Rejoins GamingBox et commence ton aventure
            </p>
        </div>

        <!-- Form -->
        <form action="/register" method="POST" class="space-y-5 relative z-10">

            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <!-- Pseudo -->
            <div>
                <label class="block text-sm mb-1 text-slate-300">
                    Pseudo
                </label>
                <input type="text" name="pseudo" required
                    class="w-full px-4 py-2 rounded-lg 
                           bg-slate-900/70 border border-slate-700 text-white
                           focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm mb-1 text-slate-300">
                    Email
                </label>
                <input type="email" name="email" required
                    class="w-full px-4 py-2 rounded-lg 
                           bg-slate-900/70 border border-slate-700 text-white
                           focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            </div>

            <!-- Password -->
            <div>
                <label class="block text-sm mb-1 text-slate-300">
                    Mot de passe
                </label>
                <input type="password" name="password" required
                    class="w-full px-4 py-2 rounded-lg 
                           bg-slate-900/70 border border-slate-700 text-white
                           focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            </div>

            <!-- Submit -->
            <button type="submit"
                class="w-full py-2.5 rounded-lg 
                       bg-gradient-to-r from-purple-600 to-indigo-600
                       hover:from-purple-500 hover:to-indigo-500
                       transition text-white font-medium
                       shadow-lg shadow-purple-600/30">
                Créer mon compte
            </button>

            <div class="flex items-start gap-2 text-sm text-slate-300"> 
                <input type="checkbox" name="gdprConsent" required class="mt-1 accent-purple-600" > 
                <span> J’accepte que mes données soient utilisées dans le cadre de l’application GamingBox. </span> 
            </div>
        </form>

        <!-- Footer -->
        <div class="mt-6 text-center text-sm text-slate-400 relative z-10">
            Déjà un compte ?
            <a href="/login" class="text-purple-400 hover:underline">
                Se connecter
            </a>
        </div>

        <div class="mt-4 text-center relative z-10">
            <a href="/" class="text-xs text-slate-500 hover:text-slate-300">
                ← Retour à l’accueil
            </a>
        </div>

    </div>

</div>