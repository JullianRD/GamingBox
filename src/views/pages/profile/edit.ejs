<!-- édition du profil par l'utilisateur -->


<div class="min-h-screen px-4 py-10 bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-white">Modifier mon profil</h1>
        <p class="text-slate-400 mt-1">
          Mets à jour tes informations personnelles
        </p>
      </div>

      <a href="/profile"
        class="px-4 py-2 rounded-lg border border-slate-700 text-slate-200 hover:bg-slate-800 transition">
        ← Retour au profil
      </a>
    </div>

    <!-- Formulaire -->
    <form action="/profile/edit" method="POST"
      class="rounded-2xl border border-purple-500/20 bg-white/5 backdrop-blur-xl shadow-2xl p-8 space-y-6">

      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Avatar -->
      <div class="flex items-center gap-6">
        <div class="w-20 h-20 rounded-full overflow-hidden bg-slate-800 flex items-center justify-center border border-purple-500/30">
          <% if (user && user.avatar) { %>
            <img src="<%= user.avatar %>" class="w-full h-full object-cover">
          <% } else { %>
            <span class="text-xl text-white font-bold">
              <%= user?.pseudo?.charAt(0).toUpperCase() || "?" %>
            </span>
          <% } %>
        </div>

        <div class="flex-1">
          <label class="block text-sm text-slate-300 mb-1">URL de l’avatar</label>
          <input type="text" name="avatar" value="<%= user?.avatar || '' %>"
            class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
        </div>
      </div>

      <!-- Pseudo -->
      <div>
        <label class="block text-sm text-slate-300 mb-1">Pseudo</label>
        <input type="text" name="pseudo" value="<%= user?.pseudo || '' %>" required
          class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
      </div>

      <!-- Email (readonly) -->
      <div>
        <label class="block text-sm text-slate-300 mb-1">Email</label>
        <input type="email" value="<%= user?.email || '' %>" disabled
          class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-400">
      </div>

      <!-- Bio -->
      <div>
        <label class="block text-sm text-slate-300 mb-1">Biographie</label>
        <textarea name="biographie" rows="4"
          class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500 focus:ring-1 focus:ring-purple-500"><%= user?.biographie || '' %></textarea>
      </div>

      <!-- Boutons -->
      <div class="flex justify-between items-center pt-4">
        <button type="submit"
          class="px-6 py-2.5 rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-500 hover:to-indigo-500 transition shadow-lg shadow-purple-900/30">
          💾 Sauvegarder
        </button>
      </div>
    </form>

    <!-- Danger zone -->
    <div class="mt-10 rounded-2xl border border-red-500/30 bg-red-500/5 p-6">
      <h2 class="text-red-400 font-semibold mb-2">Zone dangereuse</h2>
      <p class="text-sm text-slate-400 mb-4">
        La suppression de ton compte est irréversible. Toutes tes données seront perdues.
      </p>

      <form action="/profile/delete" method="POST"
        onsubmit="return confirm('Supprimer définitivement ton compte ?');">

        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <button type="submit"
          class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500 text-white transition shadow-lg shadow-red-900/30">
          🗑 Supprimer mon compte
        </button>
      </form>
    </div>

  </div>
</div>