<!-- Page du profil perso d'un utilisateur de l'app -->


<div class="min-h-screen px-4 py-10 bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900">
  <div class="max-w-4xl mx-auto">

    <!-- Header actions -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white">Mon profil</h1>
        <p class="text-slate-400 mt-1">
          Gère tes informations personnelles sur GamingBox
        </p>
      </div>

      <div class="flex gap-3">
        <a
          href="/reviews"
          class="px-4 py-2 rounded-lg border border-slate-700 text-slate-200 hover:bg-slate-800 transition"
        >
          ← Retour aux reviews
        </a>

        <a
          href="/profile/edit"
          class="px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-500 hover:to-indigo-500 transition shadow-lg shadow-purple-900/30"
        >
          Modifier le profil
        </a>
      </div>
    </div>

    <!-- Main card -->
    <div class="rounded-2xl border border-purple-500/20 bg-white/5 backdrop-blur-xl shadow-2xl overflow-hidden relative">
      <div class="absolute -top-16 -left-16 w-40 h-40 rounded-full bg-purple-600/20 blur-3xl"></div>
      <div class="absolute -bottom-16 -right-16 w-40 h-40 rounded-full bg-indigo-600/20 blur-3xl"></div>

      <div class="relative z-10 p-8">
        <div class="flex flex-col md:flex-row gap-8 items-start">

          <!-- Avatar -->
          <div class="shrink-0">
            <div class="w-28 h-28 rounded-full overflow-hidden border-2 border-purple-500/30 bg-slate-800 flex items-center justify-center shadow-lg shadow-purple-900/30">
              <% if (user && user.avatar) { %>
                <img
                  src="<%= user.avatar %>"
                  alt="Photo de profil"
                  class="w-full h-full object-cover"
                >
              <% } else { %>
                <span class="text-3xl font-bold text-slate-200">
                  <%= user && user.pseudo ? user.pseudo.charAt(0).toUpperCase() : "?" %>
                </span>
              <% } %>
            </div>
          </div>

          <!-- Infos -->
          <div class="flex-1 w-full">
            <div class="mb-6">
              <h2 class="text-2xl font-bold text-white">
                <%= user?.pseudo || "Utilisateur" %>
              </h2>
              <p class="text-slate-400 mt-1">
                <%= user?.email || "Email non disponible" %>
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Pseudo</p>
                <p class="text-white font-medium">
                  <%= user?.pseudo || "Non renseigné" %>
                </p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Email</p>
                <p class="text-white font-medium break-all">
                  <%= user?.email || "Non renseigné" %>
                </p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Rôle</p>
                <p class="text-white font-medium capitalize">
                  <%= user?.role || "visiteur" %>
                </p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Avatar</p>
                <p class="text-white font-medium">
                  <%= user?.avatar ? "Personnalisé" : "Avatar par défaut" %>
                </p>
              </div>
            </div>

            <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-5">
              <p class="text-xs uppercase tracking-wide text-slate-500 mb-2">Biographie</p>
              <p class="text-slate-200 leading-relaxed">
                <%= user?.biographie || "Aucune biographie pour le moment. Tu peux personnaliser ton profil en ajoutant une bio." %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom actions mobile-friendly -->
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <a
        href="/reviews"
        class="w-full sm:w-auto text-center px-4 py-2 rounded-lg border border-slate-700 text-slate-200 hover:bg-slate-800 transition"
      >
        ← Retour aux reviews
      </a>

      <a
        href="/profile/edit"
        class="w-full sm:w-auto text-center px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-500 hover:to-indigo-500 transition shadow-lg shadow-purple-900/30"
      >
        Modifier le profil
      </a>
    </div>
  </div>
</div>