<!-- Modification d'une review par l'utilisateur -->

<div class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900 px-4 py-10">
  <div class="mx-auto max-w-4xl">

    <!-- Header -->
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">Modifier la review</h1>
        <p class="mt-1 text-sm text-slate-400">
          Mets à jour ton avis et tes informations
        </p>
      </div>

      <a href="/reviews/<%= review.slug %>"
        class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-800">
        ← Retour au détail
      </a>
    </div>

    <!-- FORM -->
    <form action="/reviews/<%= review.slug %>" method="POST"
      class="space-y-6 rounded-2xl border border-purple-500/20 bg-white/5 p-6 shadow-2xl backdrop-blur-xl">

      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="gameId" value="<%= review.gameId %>">

      <!-- GAME INFO -->
      <div class="bg-slate-900/60 border border-slate-800 rounded-xl p-4 flex gap-4">
        <div class="w-24 h-32 bg-slate-800 rounded-lg overflow-hidden flex items-center justify-center">
          <% if (review.thumbnailUrl || review.thumbnail_url) { %>
            <img
              src="<%= review.thumbnailUrl || review.thumbnail_url %>"
              alt="<%= review.gameTitle || review.game_title || 'Jeu' %>"
              class="w-full h-full object-cover">
          <% } else { %>
            <span class="text-xs text-slate-500 text-center">Aucune image</span>
          <% } %>
        </div>

        <div class="flex-1">
          <h2 class="text-xl font-bold text-white">
            <%= review.gameTitle || review.game_title || "Jeu inconnu" %>
          </h2>

          <p class="text-sm text-slate-400 mt-2">
            Genre :
            <span><%= review.gameGenre || review.game_genre || "—" %></span>
          </p>

          <p class="text-sm text-slate-400">
            Sortie :
            <span>
              <%= review.releaseDate || review.release_date
                ? new Date(review.releaseDate || review.release_date).toLocaleDateString("fr-FR")
                : "—" %>
            </span>
          </p>
        </div>
      </div>

      <!-- TITLE -->
      <div>
        <label class="block text-sm text-slate-300 mb-2">Titre</label>
        <input
          type="text"
          name="reviewTitle"
          required
          value="<%= review.reviewTitle || review.review_title || '' %>"
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500">
      </div>

      <!-- NOTE -->
      <div>
        <label class="block text-sm text-slate-300 mb-2">Note /10</label>
        <input
          type="number"
          name="reviewRate"
          min="0"
          max="10"
          required
          value="<%= review.reviewRate || review.review_rate || 0 %>"
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500">
      </div>

      <!-- PLATFORM -->
      <div>
        <label class="block text-sm text-slate-300 mb-2">Plateforme</label>
        <select
          name="gamePlatforme"
          required
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500">
          <option value="PC" <%= (review.gamePlatforme || review.game_platforme) === "PC" ? "selected" : "" %>>PC</option>
          <option value="Console de jeu" <%= (review.gamePlatforme || review.game_platforme) === "Console de jeu" ? "selected" : "" %>>Console de jeu</option>
          <option value="Autre" <%= (review.gamePlatforme || review.game_platforme) === "Autre" ? "selected" : "" %>>Autre</option>
        </select>
      </div>

      <!-- PROGRESSION -->
      <div>
        <label class="block text-sm text-slate-300 mb-2">Progression</label>
        <select
          name="progressionStatus"
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white">
          <option value="En cour" <%= (review.progressionStatus || review.progression_status) === "En cour" ? "selected" : "" %>>En cour</option>
          <option value="Terminé" <%= (review.progressionStatus || review.progression_status) === "Terminé" ? "selected" : "" %>>Terminé</option>
          <option value="Whislist" <%= (review.progressionStatus || review.progression_status) === "Whislist" ? "selected" : "" %>>Whislist</option>
          <option value="Dropped" <%= (review.progressionStatus || review.progression_status) === "Dropped" ? "selected" : "" %>>Dropped</option>
        </select>
      </div>

      <!-- TAGS -->
      <div>
        <label class="block text-sm text-slate-300 mb-3">Tags</label>

        <% if (tags && tags.length > 0) { %>
          <div class="flex flex-wrap gap-3 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
            <% tags.forEach(tag => { %>
              <label class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:bg-slate-800 cursor-pointer">
                <input
                  type="checkbox"
                  name="tagIds"
                  value="<%= tag.id || tag.id_tag %>"
                  class="accent-purple-600"
                  <%= selectedTagIds && selectedTagIds.includes(tag.id || tag.id_tag) ? "checked" : "" %>>
                <span><%= tag.tagName || tag.tag_name %></span>
              </label>
            <% }) %>
          </div>
        <% } else { %>
          <div class="rounded-xl border border-dashed border-slate-700 bg-slate-900/40 p-4 text-sm text-slate-400">
            Aucun tag disponible pour le moment.
          </div>
        <% } %>
      </div>

      <!-- CHECKBOX -->
      <div class="flex gap-6">
        <label class="flex items-center gap-2 text-slate-300">
          <input
            type="checkbox"
            name="reviewLike"
            class="accent-purple-600"
            <%= (review.reviewLike ?? review.review_like) === true ? "checked" : "" %>>
          J’aime 👍
        </label>

        <label class="flex items-center gap-2 text-slate-300">
          <input
            type="checkbox"
            name="reviewPlatine"
            class="accent-purple-600"
            <%= (review.reviewPlatine ?? review.review_platine) === true ? "checked" : "" %>>
          Platine 🏆
        </label>
      </div>

      <!-- REVIEW -->
      <div>
        <label class="block text-sm text-slate-300 mb-2">Avis</label>
        <textarea
          name="avisReview"
          rows="5"
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500"><%= review.avisReview || review.avis_review || "" %></textarea>
      </div>

      <!-- SUBMIT -->
      <div class="flex justify-end gap-3">
        <a href="/reviews/<%= review.slug %>"
          class="px-4 py-2 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800">
          Annuler
        </a>

        <button type="submit"
          class="px-5 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white shadow-lg">
          Enregistrer
        </button>
      </div>
    </form>
  </div>
</div>