<div class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900 text-white px-4 py-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold">🔗 Mes partages</h1>
        <p class="text-slate-400 mt-1">
          Retrouve les liens de partage que tu as créés.
        </p>
      </div>

      <a
        href="/reviews"
        class="px-4 py-2 rounded-lg border border-slate-700 text-slate-200 hover:bg-slate-800 transition"
      >
        ← Retour aux reviews
      </a>
    </div>

    <% if (flash && flash.success) { %>
      <div class="mb-6 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-emerald-300">
        <%= flash.success %>
      </div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-300">
        <%= flash.error %>
      </div>
    <% } %>

    <% if (!shares || shares.length === 0) { %>
      <div class="rounded-2xl border border-dashed border-white/10 bg-white/5 p-8 text-center text-slate-400">
        Aucun partage créé pour le moment.
      </div>
    <% } else { %>
      <div class="grid gap-4">
        <% shares.forEach(share => { %>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
              <div class="min-w-0 flex-1">

                <p class="text-xs uppercase tracking-wide text-purple-300/80 mb-2">
                  <%= share.shareType === "profile" ? "Profil" : "Review" %>
                </p>

                <% if (share.shareType === "review" && share.review) { %>
                  <div class="flex items-start gap-4">
                    <% if (share.review.thumbnailUrl) { %>
                      <img
                        src="<%= share.review.thumbnailUrl %>"
                        alt="<%= share.review.gameTitle || 'Jeu' %>"
                        class="w-16 h-20 rounded-lg object-cover border border-white/10 shrink-0"
                      >
                    <% } %>

                    <div class="min-w-0">
                      <h2 class="text-lg font-semibold text-white truncate">
                        <%= share.review.reviewTitle %>
                      </h2>

                      <p class="text-sm text-slate-400">
                        Jeu : <%= share.review.gameTitle || "Jeu" %>
                      </p>

                      <% if (share.review.slug) { %>
                        <p class="text-xs text-slate-500 mt-1">
                          Slug : <%= share.review.slug %>
                        </p>
                      <% } %>
                    </div>
                  </div>
                <% } else if (share.shareType === "profile") { %>
                  <div class="flex items-start gap-4">
                    <div class="w-14 h-14 rounded-full overflow-hidden border border-white/10 bg-slate-800 flex items-center justify-center shrink-0">
                      <% if (share.profile && share.profile.avatar) { %>
                        <img
                          src="<%= share.profile.avatar %>"
                          alt="<%= share.profile.pseudo || 'Profil' %>"
                          class="w-full h-full object-cover"
                        >
                      <% } else if (user && user.avatar) { %>
                        <img
                          src="<%= user.avatar %>"
                          alt="<%= user.pseudo || 'Profil' %>"
                          class="w-full h-full object-cover"
                        >
                      <% } else { %>
                        <span class="text-lg font-bold text-slate-200">
                          <%= (share.profile && share.profile.pseudo)
                            ? share.profile.pseudo.charAt(0).toUpperCase()
                            : (user && user.pseudo)
                              ? user.pseudo.charAt(0).toUpperCase()
                              : "?" %>
                        </span>
                      <% } %>
                    </div>

                    <div class="min-w-0">
                      <h2 class="text-lg font-semibold text-white">
                        Profil de
                        <%= (share.profile && share.profile.pseudo)
                          || (user && user.pseudo)
                          || "Utilisateur" %>
                      </h2>

                      <p class="text-sm text-slate-400">
                        Partage public en lecture seule
                      </p>

                      <% if (share.profile && share.profile.biographie) { %>
                        <p class="text-sm text-slate-500 mt-2 line-clamp-2">
                          <%= share.profile.biographie %>
                        </p>
                      <% } %>
                    </div>
                  </div>
                <% } else { %>
                  <h2 class="text-lg font-semibold text-white">
                    Ressource partagée
                  </h2>
                  <p class="text-sm text-slate-400">
                    Type non déterminé
                  </p>
                <% } %>

                <div class="mt-4 space-y-1">
                  <p class="text-sm text-slate-300 break-all">
                    Destinataire : <%= share.recipientEmail %>
                  </p>

                  <p class="text-sm text-slate-400 break-all">
                    Lien :
                    <a
                      href="/shares/access/<%= share.shareToken %>"
                      class="text-purple-300 hover:text-purple-200 transition"
                    >
                      /shares/access/<%= share.shareToken %>
                    </a>
                  </p>

                  <% if (share.createdAt) { %>
                    <p class="text-xs text-slate-500">
                      Créé le <%= new Date(share.createdAt).toLocaleDateString("fr-FR") %>
                    </p>
                  <% } %>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href="/shares/access/<%= share.shareToken %>"
                  class="px-4 py-2 rounded-lg bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-500 hover:to-indigo-500 transition text-center"
                >
                  Ouvrir
                </a>

                <form
                  action="/shares/<%= share.id %>/delete"
                  method="POST"
                  onsubmit="return confirm('Révoquer ce partage ?');"
                >
                  <button
                    type="submit"
                    class="w-full px-4 py-2 rounded-lg border border-red-500/20 bg-red-500/10 text-red-300 hover:bg-red-500/20 transition"
                  >
                    Révoquer
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>