<div class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900 px-4 py-10">
  <div class="mx-auto max-w-3xl">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">Partager mon profil</h1>
        <p class="mt-1 text-sm text-slate-400">
          Donne un accès lecture seule à ton profil.
        </p>
      </div>

      <a href="/profile"
         class="px-4 py-2 rounded-lg border border-slate-700 text-slate-200 hover:bg-slate-800 transition">
        ← Retour au profil
      </a>
    </div>

    <form action="/shares/profile" method="POST"
      class="space-y-6 rounded-2xl border border-purple-500/20 bg-white/5 p-6 shadow-2xl backdrop-blur-xl">

      <input type="hidden" name="userId" value="<%= profile.id %>">

      <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-500 mb-2">Profil partagé</p>
        <p class="text-white font-medium"><%= profile.pseudo %></p>
        <p class="text-slate-400 text-sm mt-1"><%= profile.email %></p>
      </div>

      <div>
        <label class="block text-sm text-slate-300 mb-2">Email du destinataire</label>
        <input
          type="email"
          name="recipientEmail"
          required
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500">
      </div>

      <div class="flex justify-end gap-3">
        <a href="/profile"
          class="px-4 py-2 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800">
          Annuler
        </a>

        <button type="submit"
          class="px-5 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white shadow-lg">
          Créer le partage
        </button>
      </div>
    </form>
  </div>
</div>