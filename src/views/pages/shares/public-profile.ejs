<div class="min-h-screen px-4 py-10 bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900">
  <div class="max-w-4xl mx-auto">

    <div class="rounded-2xl border border-purple-500/20 bg-white/5 backdrop-blur-xl shadow-2xl overflow-hidden relative">
      <div class="absolute -top-16 -left-16 w-40 h-40 rounded-full bg-purple-600/20 blur-3xl"></div>
      <div class="absolute -bottom-16 -right-16 w-40 h-40 rounded-full bg-indigo-600/20 blur-3xl"></div>

      <div class="relative z-10 p-8">
        <div class="mb-6">
          <p class="text-xs uppercase tracking-wide text-purple-300/80 mb-2">Profil partagé</p>
          <h1 class="text-3xl font-bold text-white">
            <%= share.profile?.pseudo || "Utilisateur" %>
          </h1>
        </div>

        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="shrink-0">
            <div class="w-28 h-28 rounded-full overflow-hidden border-2 border-purple-500/30 bg-slate-800 flex items-center justify-center shadow-lg shadow-purple-900/30">
              <% if (share.profile && share.profile.avatar) { %>
                <img
                  src="<%= share.profile.avatar %>"
                  alt="Photo de profil"
                  class="w-full h-full object-cover">
              <% } else { %>
                <span class="text-3xl font-bold text-slate-200">
                  <%= share.profile && share.profile.pseudo ? share.profile.pseudo.charAt(0).toUpperCase() : "?" %>
                </span>
              <% } %>
            </div>
          </div>

          <div class="flex-1 w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Reviews</p>
                <p class="text-white font-medium"><%= share.profile?.totalReviews ?? 0 %></p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Jeux terminés</p>
                <p class="text-white font-medium"><%= share.profile?.finishedGames ?? 0 %></p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Platines</p>
                <p class="text-white font-medium"><%= share.profile?.platineGames ?? 0 %></p>
              </div>

              <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
                <p class="text-xs uppercase tracking-wide text-slate-500 mb-1">Coups de cœur</p>
                <p class="text-white font-medium"><%= share.profile?.likedGames ?? 0 %></p>
              </div>
            </div>

            <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-5">
              <p class="text-xs uppercase tracking-wide text-slate-500 mb-2">Biographie</p>
              <p class="text-slate-200 leading-relaxed">
                <%= share.profile?.biographie || "Aucune biographie pour le moment." %>
              </p>
            </div>
          </div>
        </div>

        <p class="mt-6 text-xs text-slate-500">
          Accès lecture seule
        </p>
      </div>
    </div>
  </div>
</div>