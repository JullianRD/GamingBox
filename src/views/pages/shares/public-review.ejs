<div class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900 text-white px-4 py-6">
  <div class="max-w-5xl mx-auto rounded-3xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-md shadow-2xl">

    <div class="w-full">
      <% if (share.review && share.review.thumbnailUrl) { %>
        <img
          src="<%= share.review.thumbnailUrl %>"
          alt="<%= share.review.gameTitle || 'Jeu' %>"
          class="w-full h-[280px] md:h-[380px] object-cover">
      <% } else { %>
        <div class="w-full h-[280px] md:h-[380px] bg-slate-800 flex items-center justify-center text-slate-500 text-lg">
          Pas d’image disponible
        </div>
      <% } %>
    </div>

    <div class="p-6 md:p-8">
      <p class="text-xs uppercase tracking-wide text-purple-300/80 mb-2">Review partagée</p>

      <h1 class="text-3xl font-bold mb-2">
        <%= share.review?.reviewTitle || "Review" %>
      </h1>

      <p class="text-slate-400 mb-6">
        Partagée par <span class="text-slate-200"><%= share.user?.pseudo || "Utilisateur" %></span>
      </p>

      <div class="flex flex-wrap gap-2 mb-6">
        <% if (share.review?.gameTitle) { %>
          <span class="px-3 py-1 rounded-full bg-slate-800/80 border border-slate-700">
            🎮 <%= share.review.gameTitle %>
          </span>
        <% } %>

        <% if (share.review?.gamePlatforme) { %>
          <span class="px-3 py-1 rounded-full bg-slate-800/80 border border-slate-700">
            🕹️ <%= share.review.gamePlatforme %>
          </span>
        <% } %>

        <% if (share.review?.progressionStatus) { %>
          <span class="px-3 py-1 rounded-full bg-slate-800/80 border border-slate-700">
            📍 <%= share.review.progressionStatus %>
          </span>
        <% } %>

        <% if (share.review?.reviewRate !== null && share.review?.reviewRate !== undefined) { %>
          <span class="px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-200">
            ⭐ <%= share.review.reviewRate %>/10
          </span>
        <% } %>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-5 text-slate-200 leading-7 whitespace-pre-line">
        <%= share.review?.avisReview || "Aucun avis renseigné." %>
      </div>

      <p class="mt-6 text-xs text-slate-500">
        Accès lecture seule
      </p>
    </div>
  </div>
</div>