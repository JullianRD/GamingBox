<div
  class="min-h-screen bg-gradient-to-br from-slate-950 via-purple-700 to-slate-900 px-4 py-10"
>
  <div class="mx-auto max-w-2xl">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">Nouveau tag</h1>
        <p class="mt-1 text-sm text-slate-400">
          Crée un nouveau tag pour organiser tes reviews.
        </p>
      </div>

      <a
        href="/tags"
        class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-800"
      >
        ← Retour
      </a>
    </div>

    <form
      action="/tags"
      method="POST"
      class="space-y-6 rounded-2xl border border-purple-500/20 bg-white/5 p-6 shadow-2xl backdrop-blur-xl"
    >
      <div>
        <label class="block text-sm text-slate-300 mb-2">Nom du tag</label>
        <input
          type="text"
          name="tagName"
          required
          class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-white focus:border-purple-500"
        />
      </div>

      <div class="flex justify-end gap-3">
        <a
          href="/tags"
          class="px-4 py-2 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800"
        >
          Annuler
        </a>

        <button
          type="submit"
          class="px-5 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white shadow-lg"
        >
          Créer
        </button>
      </div>
    </form>
  </div>
</div>
